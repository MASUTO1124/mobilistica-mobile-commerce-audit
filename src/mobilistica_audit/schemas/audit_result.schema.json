{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://www.mobilistica.com/schemas/audit_result.schema.json",
  "title": "AuditResult",
  "description": "共通データ契約: runAudit() / runAuditBrowser() / analyzeCollected() の戻り値形。docs/specs/core-engine-spec.md 準拠。",
  "type": "object",
  "required": [
    "audit_id",
    "target_url",
    "final_url",
    "audited_at",
    "strategy",
    "platform",
    "data_sources",
    "mobile_score",
    "performance",
    "core_web_vitals",
    "resources",
    "images",
    "javascript",
    "css",
    "fonts",
    "third_party",
    "mobile_ux",
    "commerce_ux",
    "technical_seo",
    "security",
    "recommendations",
    "summary",
    "limitations"
  ],
  "properties": {
    "audit_id": { "type": ["string", "null"], "pattern": "^ma_[0-9a-f]+$" },
    "target_url": { "type": "string" },
    "final_url": { "type": "string" },
    "audited_at": { "type": "string", "format": "date-time" },
    "strategy": { "type": "string", "enum": ["mobile", "desktop"] },
    "data_status": { "type": "string", "enum": ["ok", "partial", "unavailable"] },
    "platform": {
      "type": "object",
      "required": ["detected", "confidence", "evidence"],
      "properties": {
        "detected": { "type": "string", "enum": ["wordpress", "woocommerce", "shopify", "other", "unknown"] },
        "confidence": { "type": "string", "enum": ["confirmed", "estimated"] },
        "evidence": { "type": "array", "items": { "type": "string" } }
      }
    },
    "data_sources": {
      "type": "array",
      "items": { "type": "string", "enum": ["psi_api", "lighthouse_local", "html_fallback"] }
    },
    "mobile_score": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
    "performance": { "type": "object" },
    "core_web_vitals": {
      "type": "object",
      "properties": {
        "lcp_ms": { "$ref": "#/definitions/cwvMetric" },
        "inp_ms": { "$ref": "#/definitions/cwvMetric" },
        "cls": { "$ref": "#/definitions/cwvMetric" },
        "tbt_ms": { "$ref": "#/definitions/cwvMetric" },
        "fcp_ms": { "$ref": "#/definitions/cwvMetric" },
        "si_ms": { "$ref": "#/definitions/cwvMetric" },
        "ttfb_ms": { "$ref": "#/definitions/cwvMetric" }
      }
    },
    "resources": { "type": "object" },
    "images": { "type": "object" },
    "javascript": { "type": "object" },
    "css": { "type": "object" },
    "fonts": { "type": "object" },
    "third_party": { "type": "object" },
    "mobile_ux": { "type": "object" },
    "commerce_ux": { "type": "object" },
    "technical_seo": { "type": "object" },
    "security": { "type": "object" },
    "recommendations": {
      "type": "array",
      "items": { "$ref": "#/definitions/finding" }
    },
    "summary": {
      "type": "object",
      "required": ["overall_score", "grade", "top_issues", "executive_summary_ja"],
      "properties": {
        "overall_score": { "type": ["number", "null"] },
        "grade": { "type": ["string", "null"], "enum": ["A", "B", "C", "D", "E", null] },
        "top_issues": { "type": "array" },
        "executive_summary_ja": { "type": "string" }
      }
    },
    "limitations": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "definitions": {
    "cwvMetric": {
      "type": "object",
      "required": ["value", "rating"],
      "properties": {
        "value": { "type": ["number", "null"] },
        "rating": { "type": ["string", "null"], "enum": ["good", "needs-improvement", "poor", null] }
      }
    },
    "finding": {
      "type": "object",
      "required": [
        "issue_id",
        "category",
        "priority",
        "title",
        "evidence",
        "business_impact",
        "recommended_fix",
        "implementation_owner",
        "estimated_effort",
        "confidence",
        "automatic_fix_possible",
        "scores",
        "platform_advice",
        "term"
      ],
      "properties": {
        "issue_id": { "type": "string" },
        "category": {
          "type": "string",
          "enum": [
            "performance",
            "images",
            "javascript_css",
            "fonts",
            "delivery",
            "mobile_ux",
            "commerce_ux",
            "technical_seo",
            "security_headers",
            "third_party"
          ]
        },
        "priority": { "type": "string", "enum": ["P0", "P1", "P2", "P3", "P4"] },
        "title": { "type": "string" },
        "evidence": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "business_impact": { "type": "string" },
        "recommended_fix": { "type": "string" },
        "implementation_owner": {
          "type": "string",
          "enum": ["operator", "designer", "frontend", "backend", "server", "seo"]
        },
        "estimated_effort": { "type": "string", "enum": ["small", "medium", "large"] },
        "confidence": { "type": "number", "minimum": 0, "maximum": 100 },
        "automatic_fix_possible": { "type": "boolean" },
        "scores": {
          "type": "object",
          "required": ["sales_impact", "mobile_ux_impact", "seo_impact", "cwv_impact", "difficulty", "cost", "certainty"],
          "properties": {
            "sales_impact": { "$ref": "#/definitions/axisScore" },
            "mobile_ux_impact": { "$ref": "#/definitions/axisScore" },
            "seo_impact": { "$ref": "#/definitions/axisScore" },
            "cwv_impact": { "$ref": "#/definitions/axisScore" },
            "difficulty": { "$ref": "#/definitions/axisScore" },
            "cost": { "$ref": "#/definitions/axisScore" },
            "certainty": { "$ref": "#/definitions/axisScore" }
          }
        },
        "platform_advice": {
          "type": "object",
          "properties": {
            "wordpress": { "type": "string" },
            "woocommerce": { "type": "string" },
            "shopify": { "type": "string" },
            "generic": { "type": "string" }
          }
        },
        "term": { "type": "string", "enum": ["immediate", "short", "mid"] }
      }
    },
    "axisScore": { "type": "integer", "minimum": 0, "maximum": 5 }
  }
}
